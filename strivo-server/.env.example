# Database (PostgreSQL via Prisma)
DATABASE_URL="postgresql://user:password@localhost:5432/strivo"

# JWT Authentication
JWT_SECRET="change-me-to-a-long-random-secret"
JWT_EXPIRES_IN="1d"
# Opcional: segredo separado para refresh token (se omitido, usa JWT_SECRET)
JWT_REFRESH_SECRET="change-me-to-another-long-random-secret"

# Password hashing (rounds between 10-12 recommended)
BCRYPT_SALT_ROUNDS=10

# Supabase (Storage)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_KEY="your-anon-key"
BUCKET_NAME="uploads"

# Server
PORT=3000
NODE_ENV="development"
